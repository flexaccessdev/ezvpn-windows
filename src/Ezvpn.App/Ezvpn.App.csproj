<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>Ezvpn.App</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x64;arm64</Platforms>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <!-- WinUI needs a RID to build. Default to win-x64 so `dotnet build` (and a
         RID-less solution build) works; publish/CI override with -r for arm64. -->
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">win-x64</RuntimeIdentifier>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Unpackaged (no MSIX): the app is delivered by a plain MSI. This triggers
         the Windows App SDK auto-initializer so no runtime install is needed. -->
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <EnableMsixTooling>false</EnableMsixTooling>
    <!-- Embeds the icon as the .exe's Win32 icon (taskbar, Alt-Tab, Explorer).
         Generated from assets\icon.svg by scripts\render-icons.ps1. -->
    <ApplicationIcon>Assets\ezvpn.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="2.2.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Ezvpn.Core\Ezvpn.Core.csproj" />
  </ItemGroup>

  <!-- Ship the .ico beside the .exe so it can be loaded at runtime for the
       window title-bar icon (AppWindow.SetIcon) and the system-tray icon. It is
       copied into the publish output, so the MSI (which harvests PublishDir)
       includes it. -->
  <ItemGroup>
    <Content Include="Assets\ezvpn.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Native DLLs (ezvpn.dll, wintun.dll) are resolved at RUNTIME (P/Invoke), so
       they are not needed to compile. native.targets downloads/stages them
       (verified by SHA256) and copies them into the build / publish output. -->
  <Import Project="..\..\native\native.targets" />

  <!-- `dotnet publish` for an unpackaged (WindowsPackageType=None) WinUI 3 app
       drops the app resource index (Ezvpn.App.pri) — it stays in the build output
       but is never added to the publish set. Without it, WinUI can't resolve its
       XAML resources (XamlControlsResources) and the app crashes at startup with a
       combase E_FAIL stowed exception before any window appears. Copy the generated
       PRI into the publish output so the MSI (which harvests PublishDir) ships it. -->
  <Target Name="CopyAppPriToPublish" AfterTargets="Publish"
          Condition="Exists('$(ProjectPriFullPath)')">
    <Copy SourceFiles="$(ProjectPriFullPath)"
          DestinationFolder="$(PublishDir)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
